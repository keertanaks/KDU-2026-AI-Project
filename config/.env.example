AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=healthcare-rag-docs
KMS_KEY_ID=your_kms_key_id_here

OPENAI_API_KEY=your_openai_api_key_here
LANGSMITH_API_KEY=your_langsmith_api_key_here

DB_HOST=localhost
DB_PORT=5432
DB_USER=healthcare_user
DB_PASSWORD=secure_password
DB_NAME=healthcare_rag

OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# Storage: set true for local dev (uploads/ dir), false for AWS S3
USE_LOCAL_STORAGE=true

# Tesseract binary path (Windows default; blank = use PATH on Linux/Mac)
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# Embedding provider: openai (production) | local (dev only, no API key required)
# local uses sentence-transformers/all-MiniLM-L6-v2 (384-d) → healthcare_chunks_local
# openai uses text-embedding-3-small (1536-d) → healthcare_chunks
# NEVER mix the two indices.
EMBEDDING_PROVIDER=openai
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
