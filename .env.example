# Copy this to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override default catalog file name (without .json extension)
CATALOG_ID=catalog

# Optional — number of layout variants to generate (default: 3, max: 5)
N_VARIANTS=3

# Optional — streamlit port
STREAMLIT_PORT=8501
